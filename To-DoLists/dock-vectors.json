{
  "$comment": "Conformance vectors for DOCK-PROTOCOL.md. Generated, not hand-edited: every CRC and sha256 is computed. Mirrored verbatim in scottmclesly/Scottina-Light and kilodash, next to DOCK-PROTOCOL.md, per its \u00a710.",
  "protocol": "DOCK-PROTOCOL.md",
  "protocol_version": 1,
  "vectors_version": "0.1.0",
  "framing": {
    "sof": "0xa5",
    "layout": "SOF u8 | TYPE u8 | SEQ u8 | LEN u16le | PAYLOAD | CRC16le over TYPE..PAYLOAD",
    "crc": {
      "name": "CRC-16/CCITT-FALSE",
      "poly": "0x1021",
      "init": "0xffff",
      "reflect": false,
      "xorout": "0x0000",
      "check_input_ascii": "123456789",
      "check_value": "0x29b1"
    },
    "strings": "u8 length + UTF-8 bytes, no NUL terminator",
    "endianness": "little, every multi-byte integer"
  },
  "conventions": {
    "wire_in": "hex bytes Prime writes to the port, verbatim \u2014 may include garbage, corruption, or several frames",
    "expect": "ordered Light->Prime frames; each has a decoded 'frame' view and exact 'wire_out' hex. Empty list = no response; Prime's per-request timeout (\u00a75) is the pass condition.",
    "light_state": "overrides applied to defaults.light_state for this vector only. 'staged' maps a path to bytes already in its .partial file; 'open_path' marks a file held open (ERR_BUSY).",
    "error_frames": "conformance requires TYPE, SEQ and code to match; the message string is informative \u2014 real firmware may word it differently. The fake Light replays wire_out verbatim.",
    "list_order": "the fake Light lists lexicographically; firmware order is unspecified. Conformance for LIST is set-equality on entries.",
    "pins_open_behavior": "true marks a vector that fixes behavior v0.1 left open \u2014 reviewed by the firmware side before ratification; a veto changes the vector AND the spec together."
  },
  "defaults": {
    "light_state": {
      "proto_version": 1,
      "product": "Scottina Light",
      "fw_version": "v1-foundation",
      "sd_present": 1,
      "clock_epoch": 0,
      "clock_quality": 0,
      "clock_set_this_boot": 0,
      "max_payload": 1024,
      "flags": 3,
      "files": {
