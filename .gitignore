# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/
.env

# Editor / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Per-device runtime state (not for version control)
config.json
*.bak
*.tmp

# Mesh channel PSKs (tools/provision_mesh.sh) — per-boat secrets
mesh-secrets.env

# Generated captures, logs and sniffs — keep the folder, ignore its contents
captures/*
!captures/.gitkeep

# Decode tables imported from USB (DBC / NMEA) — per-boat artefacts.
# Ignore imported table data, but NEVER the converter's own source: without
# these negations `tables/*` silently swallows new tables/*.py.
tables/*
!tables/.gitkeep
!tables/*.py

# Capture / log artefacts anywhere in the tree
*.cu8
*.iq
*.pcap
*.cap
*.log
*.kismet.netxml

# To-DoLists/ is scratch and ignored, EXCEPT ratified protocol
# assets, which must track. Negations below key on these exact
# name patterns — a contract named off-pattern will be silently
# untracked. Keep the suffixes.
To-DoLists/*
!To-DoLists/*-PROTOCOL.md
!To-DoLists/*-vectors.json
!To-DoLists/*-DESIGN.md
!To-DoLists/*-reference.html